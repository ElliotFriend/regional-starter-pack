# Etherfuse API Configuration
ETHERFUSE_API_KEY=""
ETHERFUSE_BASE_URL="https://api.sand.etherfuse.com"

# PDAX API Configuration (Philippines)
PDAX_USERNAME=""
PDAX_PASSWORD=""
# Default routes through the project's hosted sandbox proxy so PDAX's IP
# whitelist sees a single, stable address (see /proxy/README.md). The proxy
# adds the `/api/pdax-api` upstream path prefix on its side, so this base URL
# does NOT include it. PDAX_PROXY_SECRET below must match the proxy's secret.
#
# To call PDAX directly instead (requires PDAX to whitelist your IP first),
# set PDAX_BASE_URL="https://stage.services.sandbox.pdax.ph/api/pdax-api"
# and leave PDAX_PROXY_SECRET empty.
PDAX_BASE_URL="https://proxy.regionalstarterpack.com"
PDAX_PROXY_SECRET="3e5aee09e7c4751b0febf6e8d22d6d80e90db3cf5aa2bd7808b01e8d2be4ccce"

# Stellar Network Configuration
# Use "testnet" for testing, "public" for production
PUBLIC_STELLAR_NETWORK="testnet"
SEP1_SIGNING_KEY_SECRET=""

# USDC Asset Configuration
PUBLIC_USDC_ISSUER="GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5"
