# Etherfuse API Configuration
ETHERFUSE_API_KEY=""
ETHERFUSE_BASE_URL="https://api.sand.etherfuse.com"

# Stellar Network Configuration
# Use "testnet" for testing, "public" for production
PUBLIC_STELLAR_NETWORK="testnet"
SEP1_SIGNING_KEY_SECRET=""

# USDC Asset Configuration
PUBLIC_USDC_ISSUER="GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5"

# Cron maintenance (Vercel Cron Jobs)
# Set the same value in the Vercel project env. Vercel attaches
# `Authorization: Bearer $CRON_SECRET` to cron invocations; the routes verify it.
CRON_SECRET=""

# Blend pool maintenance (used by /api/cron/blend/*)
BLEND_EMITTER_ADDRESS=""
BLEND_BACKSTOP_ADDRESS=""
BLEND_POOL_ADDRESS=""
BLEND_ORACLE_ADDRESS=""
# Secret key (S...) of the account that signs the maintenance transactions.
BLEND_ADMIN_SECRET=""
